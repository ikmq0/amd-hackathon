# Copy to backend/.env and fill in your key. backend/.env is gitignored and loaded
# automatically on startup. Do NOT put real keys in this example file (it is committed).

# Google Gemini API key — enables the monthly report (/report) and chat (/chat).
# Get one (free tier) at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional overrides:
# MIDD_GEMINI_MODEL=gemini-flash-latest
# MIDD_API_KEY=            # set to require an X-API-Key header on requests
